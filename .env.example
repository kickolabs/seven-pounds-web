NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Rate limiting (optional — upstash.com free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email notifications (optional — resend.com free tier)
RESEND_API_KEY=
ADMIN_EMAIL=admin@thesevenpounds.in
FROM_EMAIL=noreply@thesevenpounds.in

# Razorpay webhook (optional — from Razorpay dashboard)
RAZORPAY_WEBHOOK_SECRET=

# Sentry error tracking (optional — sentry.io free tier)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# WhatsApp Business Cloud API (developers.facebook.com → WhatsApp → API Setup)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_NUMBER=
# Admin number that receives ALL lead notifications (never the customer's phone)
WHATSAPP_ADMIN_NUMBER=918925856552
# Legacy aliases (still supported):
WHATSAPP_RECIPIENT_NUMBER=918925856552
WHATSAPP_RECIPIENT_PHONE=918925856552
# Optional: protect /api/test-whatsapp in production (?secret=...)
WHATSAPP_TEST_SECRET=
