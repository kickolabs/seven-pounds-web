NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Rate limiting (optional — upstash.com free tier)
UPSTASH_REDIS_REST_URL=
